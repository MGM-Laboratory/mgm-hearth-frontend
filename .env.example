# =============================================================================
# mgm-hearth-frontend — Next.js (Hearth: admin + maintainer)
#
# Copy to `.env.local` (Next.js convention) or `.env`. This file is the
# self-sufficient set of env vars the app needs to run on its own in an
# independent Docker container. Variables prefixed `NEXT_PUBLIC_` are inlined
# at build time and exposed to the browser; everything else is server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development                       # development | staging | production
APP_TIMEZONE=Asia/Jakarta
APP_DEFAULT_LOCALE=en                     # en | id

# -----------------------------------------------------------------------------
# HEARTH_* — this app
# -----------------------------------------------------------------------------
HEARTH_PORT=3000
HEARTH_PUBLIC_URL=http://localhost:3000   # canonical external URL — MUST be this app's host (e.g. https://hearth.labmgm.org in prod), never Keycloak's
HEARTH_AUTH_URL=http://localhost:3000     # Auth.js (NextAuth v5) base URL — used to build /api/auth/* + the OAuth redirect_uri; mirror HEARTH_PUBLIC_URL
HEARTH_AUTH_SECRET=change-me-min-32-chars-please   # Auth.js (NextAuth v5) session encryption secret (REQUIRED)

# -----------------------------------------------------------------------------
# Backend API
#   HEARTH_API_URL          → browser-facing API base (used in client components)
#   HEARTH_API_URL_INTERNAL → SSR-facing API base (used inside the cluster)
#   NEXT_PUBLIC_API_URL     → exposed to the browser; falls back to HEARTH_API_URL
# -----------------------------------------------------------------------------
HEARTH_API_URL=http://localhost:8080/api/v1
HEARTH_API_URL_INTERNAL=http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# -----------------------------------------------------------------------------
# Keycloak OIDC (REQUIRED for sign-in)
# -----------------------------------------------------------------------------
KEYCLOAK_ISSUER_URL=https://iam.labmgm.org/realms/mgm
KEYCLOAK_CLIENT_ID_HEARTH=hearth-web
KEYCLOAK_CLIENT_SECRET_HEARTH=change-me
KEYCLOAK_IT_GROUP=/member/it-infrastructure   # marks Maintainer; non-members hit /not-it

# Public account-management URL (profile menu "Edit profile" link)
NEXT_PUBLIC_KEYCLOAK_ACCOUNT_URL=https://iam.labmgm.org/realms/mgm/account

# Bootstrap admin (mirrors backend; informational on the UI side)
BOOTSTRAP_ADMIN_EMAIL=admin@labmgm.org

# -----------------------------------------------------------------------------
# Cross-app links
# -----------------------------------------------------------------------------
PINJAM_PUBLIC_URL=http://localhost:3001
NEXT_PUBLIC_PINJAM_URL=http://localhost:3001

# Public QR asset detail base (the URL embedded in printed sticker QR codes)
APP_PUBLIC_ASSET_BASE_URL=http://localhost:3000/a
NEXT_PUBLIC_PUBLIC_ASSET_BASE_URL=http://localhost:3000/a

# -----------------------------------------------------------------------------
# Sentry
# -----------------------------------------------------------------------------
SENTRY_DSN_HEARTH=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# -----------------------------------------------------------------------------
# Playwright (E2E only — leave blank in production)
# -----------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_SKIP_WEB_SERVER=
